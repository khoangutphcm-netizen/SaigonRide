<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SaigonRide Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">
    <style>
        body { background-color: #f4f6f8; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; overflow: hidden; height: 100vh; margin: 0; }
         
        .sidebar { background: linear-gradient(180deg, #084c61 0%, #177e89 50%, #21a3a6 100%); height: 100vh; overflow-y: auto; overflow-x: hidden; color: white; display: flex; flex-direction: column; flex-shrink: 0; z-index: 10; position: relative; }
        
        .sidebar > * { position: relative; z-index: 1; }
        
        .sidebar::before { content: ''; position: absolute; top: -50px; left: -50px; width: 200px; height: 200px; background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%); border-radius: 50%; pointer-events: none; z-index: 0; }
        .sidebar::after { content: ''; position: absolute; top: 40%; right: -60px; width: 150px; height: 150px; background: radial-gradient(circle, rgba(255,255,255,0.05) 0%, transparent 70%); border-radius: 50%; pointer-events: none; z-index: 0; }
        
        .deco-star { position: absolute; color: rgba(255,255,255,0.15); pointer-events: none; z-index: 0; animation: float 5s infinite ease-in-out; }
        .deco-star-1 { top: 15%; left: 15px; font-size: 1.5rem; animation-delay: 0s; }
        .deco-star-2 { top: 60%; right: 20px; font-size: 1.2rem; animation-delay: 2s; }
        .deco-star-3 { top: 35%; left: 80%; font-size: 0.8rem; animation-delay: 1s; }
        
        .deco-wave { position: absolute; bottom: 0; left: 0; width: 100%; height: auto; opacity: 0.15; pointer-events: none; z-index: 0; }
        
        @@keyframes float { 0%, 100% { transform: translateY(0) rotate(0deg); } 50% { transform: translateY(-10px) rotate(5deg); } }

        .sidebar-logo { font-size: 1.5rem; font-weight: bold; color: white; text-decoration: none; padding: 1.5rem 1rem; display: flex; flex-direction: column; align-items: center; }
        .nav-link { color: rgba(255, 255, 255, 0.8); padding: 0.8rem 1.5rem; display: flex; align-items: center; gap: 10px; transition: all 0.3s; }
        .nav-link:hover, .nav-link.active { color: white; background-color: rgba(255, 255, 255, 0.15); border-radius: 8px; margin: 0 10px; }
         
        .user-panel { margin: 15px; padding: 10px; margin-top: auto; }
        
        .logout-btn { background: rgba(220, 53, 69, 0.15); color: #ffb3b3; border: 1px solid rgba(220, 53, 69, 0.3); transition: all 0.3s; }
        .logout-btn:hover { background: #dc3545; color: white; border-color: #dc3545; box-shadow: 0 5px 15px rgba(220, 53, 69, 0.4); transform: translateY(-2px); }
        
        .main-wrapper { height: 100vh; overflow-y: auto; overflow-x: hidden; background-color: #f4f6f8; flex-grow: 1; }
        .main-content { padding: 2rem; }
    </style>
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    }
    <div class="d-flex w-100 h-100">
        <div class="sidebar col-auto col-md-3 col-xl-2 px-0 shadow">
            <i class="bi bi-stars deco-star deco-star-1"></i>
            <i class="bi bi-star-fill deco-star deco-star-2"></i>
            <i class="bi bi-moon-stars-fill deco-star deco-star-3"></i>
            
            <svg class="deco-wave" viewBox="0 0 1440 320" xmlns="http://www.w3.org/2000/svg">
                <path fill="#ffffff" fill-opacity="1" d="M0,224L48,213.3C96,203,192,181,288,181.3C384,181,480,203,576,224C672,245,768,267,864,261.3C960,256,1056,224,1152,197.3C1248,171,1344,149,1392,138.7L1440,128L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
            </svg>

            <a href="/AdminDashboard/Index" class="sidebar-logo">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <i class="bi bi-scooter text-success"></i>
                    <span>SaigonRide</span>
                </div>
                <span class="badge bg-danger rounded-pill" style="font-size: 0.8rem;">ADMIN</span>
            </a>
            
            <hr class="mx-3 opacity-25">

            <ul class="nav flex-column mb-auto">
                <li class="nav-item">
                    <a href="/Home/Index" class="nav-link text-info fw-bold">
                        <i class="bi bi-phone"></i>
                        <span>Xem giao diện<br><small>Khách (App)</small></span>
                    </a>
                </li>
                <li class="nav-item mt-3"><a href="/AdminDashboard/Index" class="nav-link @(currentController == "AdminDashboard" && currentAction != "Announcements" ? "active" : "")"><i class="bi bi-speedometer2"></i><span>Tổng quan</span></a></li>
                <li class="nav-item"><a href="/AdminStation/Index" class="nav-link @(currentController == "AdminStation" ? "active" : "")"><i class="bi bi-geo-alt"></i><span>Quản lý Trạm</span></a></li>
                <li class="nav-item"><a href="/AdminVehicle/Index" class="nav-link @(currentController == "AdminVehicle" ? "active" : "")"><i class="bi bi-bicycle"></i><span>Quản lý Xe</span></a></li>
                <li class="nav-item"><a href="/AdminUser/Index" class="nav-link @(currentController == "AdminUser" ? "active" : "")"><i class="bi bi-people"></i><span>Quản lý User</span></a></li>
                <li class="nav-item"><a href="/Transactions/Index" class="nav-link @(currentController == "Transactions" ? "active" : "")"><i class="bi bi-receipt"></i><span>Giao dịch & Báo cáo</span></a></li>
                <li class="nav-item"><a href="/Reports/AdminReports" class="nav-link @(currentController == "Reports" ? "active" : "")"><i class="bi bi-flag-fill"></i><span>Quản lý Phản hồi</span></a></li>
                <li class="nav-item"><a href="/AdminDashboard/Announcements" class="nav-link @(currentController == "AdminDashboard" && currentAction == "Announcements" ? "active" : "")"><i class="bi bi-megaphone"></i><span>Quản lý Thông báo</span></a></li>
            </ul>

            <div class="user-panel">
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="btn logout-btn w-100 rounded-pill fw-bold py-2">
                        <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
                    </button>
                </form>
            </div>
        </div>

        <div class="main-wrapper">
            <div class="main-content">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>