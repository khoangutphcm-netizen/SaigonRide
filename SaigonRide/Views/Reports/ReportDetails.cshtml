@model SaigonRide.Models.entities.Report
@{
    ViewData["Title"] = Localizer["ReportDetailsTitle"].Value;
}

<div class="container py-4">
    <div class="d-flex align-items-center mb-4 gap-3">
        <a href="/Reports/MyReports" class="btn btn-white bg-white shadow-sm rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
            <i class="bi bi-arrow-left text-dark"></i>
        </a>
        <div>
            <h3 class="fw-bold text-dark mb-0">Báo cáo #@Model.Id</h3>
            <p class="text-muted mb-0">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")</p>
        </div>
    </div>

    <div class="row g-4">
        <!-- User Report Section -->
        <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
            <h5 class="fw-bold text-dark mb-3">@Localizer["YourReport"]</h5>
            <div class="mb-3">
                <label class="text-muted small fw-bold mb-2">@Localizer["ReportColStatus"]</label>
                <span class="badge bg-@(Model.Status == SaigonRide.Models.entities.ReportStatus.Open ? "warning" : (Model.Status == SaigonRide.Models.entities.ReportStatus.Resolved ? "success" : (Model.Status == SaigonRide.Models.entities.ReportStatus.InProgress ? "info" : "secondary")))" style="font-size: 0.9rem; padding: 8px 12px;">
                    @(Model.Status == SaigonRide.Models.entities.ReportStatus.Open ? Localizer["StatusOpen"] : (Model.Status == SaigonRide.Models.entities.ReportStatus.InProgress ? Localizer["StatusInProgress"] : (Model.Status == SaigonRide.Models.entities.ReportStatus.Resolved ? Localizer["StatusResolved"] : Localizer["StatusClosed"])))
                </span>
            </div>
            <div class="mb-3">
                <label class="text-muted small fw-bold mb-2">@Localizer["ReportColTitle"]</label>
                <p class="mb-0">@Model.Title</p>
            </div>
            <div class="mb-3">
                <label class="text-muted small fw-bold mb-2">@Localizer["ReportContent"]</label>
                <p class="mb-0">@Model.Description</p>
            </div>
            <div class="mb-3">
                <label class="text-muted small fw-bold mb-2">@Localizer["RelatedRideId"]</label>
                <p class="mb-0">#@Model.RentalTransactionId</p>
            </div>
            <div class="mb-3">
                <label class="text-muted small fw-bold mb-2">@Localizer["ReportColDateSent"]</label>
                <p class="mb-0">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")</p>
            </div>
        </div>

        <!-- Admin Response Section -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
                <h5 class="fw-bold text-dark mb-3">
                    <i class="bi bi-chat-left-dots text-success me-2"></i>
                    @Localizer["AdminResponseTitle"]
                </h5>

                @if (string.IsNullOrEmpty(Model.AdminResponse))
                {
                    <div class="alert alert-info" role="alert">
                        <i class="bi bi-info-circle me-2"></i>
                        @Localizer["NoResponseYet"]
                    </div>
                }
                else
                {
                    <div class="bg-light p-3 rounded-3 mb-3">
                        <p class="mb-0">@Model.AdminResponse</p>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted small fw-bold mb-2">@Localizer["ResponseStatus"]</label>
                        <p class="mb-0">
                            <strong>@(Model.Status == SaigonRide.Models.entities.ReportStatus.Open ? Localizer["StatusOpen"] : (Model.Status == SaigonRide.Models.entities.ReportStatus.InProgress ? Localizer["StatusInProgress"] : (Model.Status == SaigonRide.Models.entities.ReportStatus.Resolved ? Localizer["StatusResolved"] : Localizer["StatusClosed"])))</strong> -
                            @if (Model.RespondedAt.HasValue)
                            {
                                <span class="text-muted">@Model.RespondedAt.Value.ToString("dd/MM/yyyy HH:mm:ss")</span>
                            }
                        </p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
