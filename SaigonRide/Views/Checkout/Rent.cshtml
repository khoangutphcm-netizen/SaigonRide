@model SaigonRide.Models.entities.Vehicle
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["PageTitle"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml"; 
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.js"></script>

<style>
    #heroMap { position: absolute; top: 60px; bottom: 0; left: 0; right: 0; z-index: 1; }
    .floating-card { position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%); z-index: 1000; width: 90%; max-width: 450px; background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); border-radius: 24px; box-shadow: 0 15px 35px rgba(0,0,0,0.2); }
    .leaflet-routing-container { display: none !important; }
</style>

<div id="heroMap"></div>

<div class="floating-card overflow-hidden border border-white">
    <div class="bg-success text-white p-3 d-flex justify-content-between align-items-center">
        <h5 class="fw-bold mb-0 d-flex align-items-center gap-2">
            <i class="bi @(Model.Category.Contains("Scooter") ? "bi-scooter" : "bi-bicycle") fs-3"></i>
            @Model.Category
        </h5>
        <span class="badge bg-white text-success rounded-pill px-3 py-2">SR-@Model.Id</span>
    </div>
    
    <div class="p-4">
        <div class="d-flex justify-content-between align-items-end mb-3">
            <div>
                <small class="text-muted text-uppercase fw-bold">@Localizer["Price"]</small>
                <h3 class="fw-bold text-dark mb-0">@Model.PricePerMinute.ToString("N0")đ<span class="fs-6 text-muted">/min</span></h3>
            </div>
            <div class="text-end">
                <small class="text-muted fw-bold d-block">@Localizer["PickupPoint"]</small>
                <h6 class="text-dark fw-bold mb-0">@Model.Station.LocationName <span id="rent-dist" class="badge bg-primary ms-1" style="display:none;"></span></h6>
            </div>
        </div>

        <form asp-controller="Checkout" asp-action="StartTimer" method="post" class="mt-4">
            <input type="hidden" name="vehicleId" value="@Model.Id" />
            <button type="submit" class="btn btn-success w-100 py-3 fw-bold fs-5 rounded-pill shadow-lg d-flex justify-content-center align-items-center gap-2">
                @Localizer["StartRental"] <i class="bi bi-unlock-fill"></i>
            </button>
        </form>
    </div>
</div>

<script>
    var stationLat = @(Model.Station.Latitude != 0 ? Model.Station.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture) : "10.776889");
    var stationLng = @(Model.Station.Longitude != 0 ? Model.Station.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture) : "106.700806");

    var map = L.map('heroMap', { zoomControl: false }).setView([stationLat, stationLng], 16);
    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
     
    var stationIcon = L.divIcon({
        className: 'custom-div-icon',
        html: `<div class="bg-white rounded-circle shadow-lg border border-4 border-success d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;"><i class="bi @(Model.Category.Contains("Scooter") ? "bi-scooter" : "bi-bicycle") text-success fs-3"></i></div>`,
        iconSize: [50, 50], iconAnchor: [25, 50]
    });
    L.marker([stationLat, stationLng], { icon: stationIcon }).addTo(map).bindTooltip("@Localizer["PickupPoint"]", { direction: 'top', offset: [0, -45] }).openTooltip();

    if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(function (position) {
            var userLat = position.coords.latitude;
            var userLng = position.coords.longitude; 
            
            var R = 6371; var dLat = (stationLat - userLat) * Math.PI / 180; var dLon = (stationLng - userLng) * Math.PI / 180;
            var a = Math.sin(dLat/2) * Math.sin(dLat/2) + Math.cos(userLat * Math.PI / 180) * Math.cos(stationLat * Math.PI / 180) * Math.sin(dLon/2) * Math.sin(dLon/2);
            var distKm = R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
            document.getElementById('rent-dist').innerText = distKm < 1 ? (distKm * 1000).toFixed(0) + " m" : distKm.toFixed(1) + " km";
            document.getElementById('rent-dist').style.display = 'inline-block';

            var userIcon = L.divIcon({
                className: 'custom-div-icon',
                html: `<div class="bg-primary text-white rounded-circle shadow-lg border border-4 border-white d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;"><i class="bi bi-person-fill fs-5"></i></div>`,
                iconSize: [40, 40], iconAnchor: [20, 20]
            });
            L.marker([userLat, userLng], { icon: userIcon }).addTo(map);

            L.Routing.control({
                waypoints: [L.latLng(userLat, userLng), L.latLng(stationLat, stationLng)],
                routeWhileDragging: false, addWaypoints: false, show: false,
                createMarker: function() { return null; },
                lineOptions: { styles: [{color: '#00c853', opacity: 0.8, weight: 6, dashArray: '10, 10' }] }
            }).addTo(map);

            var bounds = L.latLngBounds([[userLat, userLng], [stationLat, stationLng]]);
            map.fitBounds(bounds, { padding: [80, 80] });  
        });
    }
    function checkLiveAvailability() {
            fetch('/Checkout/GetLiveStationsData').then(r => r.json()).then(data => {
                let vehicleStillExists = false;
                data.forEach(st => {
                    if(st.vehicles && st.vehicles.some(v => v.id === @Model.Id)) {
                        vehicleStillExists = true;
                    }
                });
                if(!vehicleStillExists) {
                    alert("Rất tiếc! Chiếc xe này vừa được người khác thuê mất. Vui lòng chọn chiếc khác.");
                    window.location.href = "/Booking/Index";
                }
            });
        }
    
    setInterval(checkLiveAvailability, 5000);

</script>