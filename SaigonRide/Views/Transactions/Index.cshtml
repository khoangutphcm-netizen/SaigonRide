@model IEnumerable<SaigonRide.Models.entities.RentalTransaction>
@{
    ViewData["Title"] = "Lịch sử Giao dịch";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .table-custom { border-collapse: separate; border-spacing: 0 8px; }
    .table-custom thead th { border: none; background: transparent; color: #6c757d; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; padding-bottom: 0; }
    .table-custom tbody tr { background-color: #fff; box-shadow: 0 2px 6px rgba(0,0,0,0.02); border-radius: 10px; transition: all 0.2s; cursor: pointer; }
    .table-custom tbody tr:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(0,0,0,0.08); background-color: #f8faff; border-left: 4px solid #0d6efd; }
    .table-custom tbody td { border-top: 1px solid #f0f0f0; border-bottom: 1px solid #f0f0f0; vertical-align: middle; padding: 1rem 1.2rem; }
    .table-custom tbody td:first-child { border-left: 1px solid #f0f0f0; border-top-left-radius: 10px; border-bottom-left-radius: 10px; }
    .table-custom tbody td:last-child { border-right: 1px solid #f0f0f0; border-top-right-radius: 10px; border-bottom-right-radius: 10px; }
    
    .status-badge { padding: 6px 12px; border-radius: 20px; font-weight: 600; font-size: 0.75rem; }
    .status-completed { background-color: rgba(25, 135, 84, 0.1); color: #198754; border: 1px solid rgba(25, 135, 84, 0.2); }
    .status-ongoing { background-color: rgba(253, 126, 20, 0.1); color: #fd7e14; border: 1px solid rgba(253, 126, 20, 0.2); }
    
    .search-container { background: #fff; border-radius: 50rem; padding: 5px; box-shadow: 0 4px 15px rgba(0,0,0,0.03); border: 1px solid #eaeaea; }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold text-dark mb-0"><i class="bi bi-receipt-cutoff text-primary me-2"></i>Quản lý Giao dịch & Báo cáo</h4>
    
    <form method="get" asp-action="Index" class="d-flex search-container w-25" style="min-width: 320px;">
        <input type="text" name="searchString" value="@ViewBag.CurrentSearch" class="form-control border-0 shadow-none bg-transparent ps-3" placeholder="Tìm kiếm GD, Khách..." />
        <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">Tìm</button>
        @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch))
        {
            <a href="/Transactions/Index" class="btn btn-light rounded-circle text-muted ms-1 d-flex align-items-center justify-content-center" style="width: 38px; height: 38px;"><i class="bi bi-x-lg"></i></a>
        }
    </form>
</div>

<div class="table-responsive" style="min-height: 60vh;">
    <table class="table table-custom w-100">
        <thead>
            <tr>
                <th class="ps-4">Mã GD</th>
                <th>Khách hàng</th>
                <th>Phương tiện</th>
                <th>Thời gian</th>
                <th>Tổng tiền</th>
                <th class="text-end pe-4">Trạng thái</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    var isOngoing = item.EndTime == null;
                    var statusClass = isOngoing ? "status-ongoing" : "status-completed";
                    var statusText = isOngoing ? "Đang thuê" : "Hoàn tất";
                    var totalDueText = isOngoing ? "---" : item.TotalDue.ToString("N0") + " ₫";
                    
                    var startTimeStr = item.StartTime.AddHours(7).ToString("dd/MM/yyyy HH:mm:ss");
                    var endTimeStr = item.EndTime?.AddHours(7).ToString("dd/MM/yyyy HH:mm:ss") ?? "Chưa kết thúc";
                    var duration = isOngoing ? "---" : Math.Ceiling((item.EndTime.Value - item.StartTime).TotalMinutes).ToString() + " phút";
                    var discountText = item.IsDiscountApplied ? "Có (-15%)" : "Không";
                    var returnStation = item.ReturnStationId?.ToString() ?? "Chưa có";
                    
                    <tr onclick="showTxDetails('@item.Id', '@Html.Raw(item.User?.FullName ?? "Unknown")', '@Html.Raw(item.Vehicle?.Category ?? "Unknown")', '@item.VehicleId', '@startTimeStr', '@endTimeStr', '@duration', '@totalDueText', '@statusText', '@statusClass', '@discountText', '@returnStation')">
                        <td class="ps-4 fw-bold text-primary">#@item.Id.ToString("D5")</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="bg-secondary bg-opacity-10 text-secondary rounded-circle d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;"><i class="bi bi-person"></i></div>
                                <span class="fw-bold text-dark">@item.User?.FullName</span>
                            </div>
                        </td>
                        <td>
                            <div class="text-dark fw-medium"><i class="bi @(item.Vehicle?.Category != null && item.Vehicle.Category.Contains("Scooter") ? "bi-scooter" : "bi-bicycle") text-muted me-1"></i> @item.Vehicle?.Category</div>
                        </td>
                        <td>
                            <small class="text-muted d-block"><i class="bi bi-play-circle text-success me-1"></i>@item.StartTime.AddHours(7).ToString("dd/MM HH:mm")</small>
                            @if(!isOngoing) { <small class="text-muted d-block"><i class="bi bi-stop-circle text-danger me-1"></i>@item.EndTime.Value.ToString("dd/MM HH:mm")</small> }
                        </td>
                        <td class="fw-bold @(isOngoing ? "text-muted" : "text-success")">@totalDueText</td>
                        <td class="text-end pe-4"><span class="status-badge @statusClass">@statusText</span></td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6" class="text-center py-5 text-muted bg-white rounded-3 shadow-sm border"><i class="bi bi-inbox fs-2 d-block mb-2"></i>Không tìm thấy giao dịch nào.</td></tr>
            }
        </tbody>
    </table>
</div>

<div class="modal fade" id="txDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header bg-light border-0 pb-0">
                <h5 class="modal-title fw-bold text-dark" id="modalTitle">Chi tiết Giao dịch</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="bg-light p-4 text-center border-bottom">
                    <div class="d-inline-flex align-items-center justify-content-center bg-white rounded-circle shadow-sm text-primary mb-2" style="width: 60px; height: 60px; font-size: 1.8rem;">
                        <i class="bi bi-receipt"></i>
                    </div>
                    <h4 class="fw-bold text-dark mb-2" id="m-total">0 ₫</h4>
                    <span class="status-badge" id="m-status">Trạng thái</span>
                </div>
                <div class="p-4">
                    <div class="row mb-3">
                        <div class="col-6"><small class="text-muted">Mã Giao Dịch</small><div class="fw-bold text-dark" id="m-id"></div></div>
                        <div class="col-6"><small class="text-muted">Khách Hàng</small><div class="fw-bold text-dark" id="m-user"></div></div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-6"><small class="text-muted">Phương Tiện</small><div class="fw-bold text-dark" id="m-vehicle"></div></div>
                        <div class="col-6"><small class="text-muted">Mã Xe</small><div class="fw-bold text-dark">SR-<span id="m-vid"></span></div></div>
                    </div>
                    <hr class="text-muted opacity-25">
                    <div class="row mb-3">
                        <div class="col-6"><small class="text-muted">Bắt đầu</small><div class="fw-medium text-dark" id="m-start"></div></div>
                        <div class="col-6"><small class="text-muted">Kết thúc</small><div class="fw-medium text-dark" id="m-end"></div></div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-6"><small class="text-muted">Thời lượng</small><div class="fw-medium text-dark" id="m-duration"></div></div>
                        <div class="col-6"><small class="text-muted">Trạm kết thúc (ID)</small><div class="fw-medium text-dark" id="m-station"></div></div>
                    </div>
                    <div class="row">
                        <div class="col-12"><small class="text-muted">Khuyến mãi (Thiếu xe trạm đích)</small><div class="fw-bold text-success" id="m-discount"></div></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0 justify-content-center">
                <button type="button" class="btn btn-light fw-bold rounded-pill px-4 border shadow-sm" data-bs-dismiss="modal">Đóng cửa sổ</button>
            </div>
        </div>
    </div>
</div>

<script>
    function showTxDetails(id, user, vehicle, vid, start, end, duration, total, statusText, statusClass, discount, station) {
        document.getElementById('m-id').innerText = '#' + id.padStart(5, '0');
        document.getElementById('m-user').innerText = user;
        document.getElementById('m-vehicle').innerText = vehicle;
        document.getElementById('m-vid').innerText = vid;
        document.getElementById('m-start').innerText = start;
        document.getElementById('m-end').innerText = end;
        document.getElementById('m-duration').innerText = duration;
        document.getElementById('m-total').innerText = total;
        document.getElementById('m-discount').innerText = discount;
        document.getElementById('m-station').innerText = station;
        
        let statusEl = document.getElementById('m-status');
        statusEl.innerText = statusText;
        statusEl.className = 'status-badge ' + statusClass;
        
        var modal = new bootstrap.Modal(document.getElementById('txDetailModal'));
        modal.show();
    }
</script>