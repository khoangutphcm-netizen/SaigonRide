@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    Layout = null; 
    var isEnglish = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("en");
}

<!DOCTYPE html>
<html lang="@(System.Globalization.CultureInfo.CurrentUICulture.Name)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SaigonRide - Lái xe xanh, sống an lành</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">
    
    <style>
        body, html { 
            margin: 0; padding: 0; height: 100%; 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            overflow-x: hidden; 
         }

         .bg-hcmc {
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
            
             background-image: url('/images/intro.png'); 
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            
             z-index: 0; 
            animation: slowPan 35s ease-in-out infinite alternate;
        }
         
        .bg-overlay {
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
            background: linear-gradient(135deg, rgba(5, 19, 26, 0.7) 0%, rgba(15, 76, 92, 0.4) 100%);
         
            z-index: 1; 
        }

        @@keyframes slowPan {
            0% { transform: scale(1) translate(0, 0); }
            100% { transform: scale(1.1) translate(-10px, 10px); }
        }
         
        .glass-panel {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5), inset 0 0 0 1px rgba(255, 255, 255, 0.05);
            border-radius: 2rem;
        }

        .glass-pill {
            background: rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 50px;
            padding: 4px;
        }
         
        @@keyframes aurora-shift {
            0% { background-position: 0% 50%; box-shadow: 0 0 10px rgba(0, 255, 128, 0.4); }
            50% { background-position: 100% 50%; box-shadow: 0 0 30px rgba(0, 255, 128, 0.7); }
            100% { background-position: 0% 50%; box-shadow: 0 0 10px rgba(0, 255, 128, 0.4); }
        }
        .btn-aurora {
            background: linear-gradient(90deg, #00c853, #1de9b6, #00e676, #00c853);
            background-size: 200% 100%; animation: aurora-shift 3s ease infinite;
            border: none; color: #fff !important; font-weight: 800; text-transform: uppercase; letter-spacing: 1px;
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        }
        .btn-aurora:hover { transform: translateY(-3px) scale(1.02); box-shadow: 0 10px 40px rgba(0, 255, 128, 0.8); animation-duration: 1.5s; }
         
        .fade-in-up { animation: fadeInUp 1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; opacity: 0; transform: translateY(30px); }
        .delay-1 { animation-delay: 0.2s; }
        .delay-2 { animation-delay: 0.4s; }

        @@keyframes fadeInUp { to { opacity: 1; transform: translateY(0); } }
         
        .float-icon { animation: float 6s ease-in-out infinite; filter: drop-shadow(0 0 20px rgba(0, 200, 83, 0.8)); }
        @@keyframes float { 0% { transform: translateY(0px); } 50% { transform: translateY(-15px); } 100% { transform: translateY(0px); } }
    </style>
</head>
<body class="position-relative">

    <div class="bg-hcmc"></div>
    <div class="bg-overlay"></div>

    <div class="position-absolute top-0 w-100 p-4 d-flex justify-content-between align-items-center z-3 fade-in-up">
        <div class="d-flex align-items-center gap-2 text-white">
            <i class="bi bi-scooter text-success fs-3 float-icon" style="animation-duration: 4s;"></i>
            <h4 class="fw-bold mb-0" style="letter-spacing: 1px;">SaigonRide</h4>
        </div>

        <div class="glass-pill d-flex align-items-center">
            <button onclick="switchLanguage('vi')" class="btn btn-sm rounded-pill px-3 @(!isEnglish ? "bg-white text-success fw-bold shadow-sm" : "text-white")" style="transition: all 0.3s;">
                🇻🇳 VI
            </button>
            <button onclick="switchLanguage('en')" class="btn btn-sm rounded-pill px-3 @(isEnglish ? "bg-white text-success fw-bold shadow-sm" : "text-white")" style="transition: all 0.3s;">
                🇬🇧 EN
            </button>
        </div>
    </div>

    <div class="container h-100 d-flex align-items-center justify-content-center position-relative z-2">
        <div class="glass-panel p-5 text-center fade-in-up delay-1" style="max-width: 850px;">
            <i class="bi bi-geo-alt-fill text-success mb-3 d-block float-icon" style="font-size: 4rem;"></i>
            
            <h1 class="display-3 fw-bolder text-white mb-4" style="text-shadow: 0 4px 20px rgba(0,0,0,0.5);">
                @Html.Raw(isEnglish ? "Saigon<span class='text-success'>Ride</span>" : "Saigon<span class='text-success'>Ride</span>")
            </h1>
            
            <p class="lead mb-5 fw-medium" style="color: rgba(255,255,255,0.85); line-height: 1.8; font-size: 1.15rem;">
                @(isEnglish ? "Forget traffic jams and exhaust fumes. SaigonRide brings the smartest, most convenient, and eco-friendly mobility solution to the city. Unlock a bike and start your journey for less than the cost of an iced tea." : "Kẹt xe? Khói bụi? Quên đi! SaigonRide mang đến giải pháp di chuyển thông minh, tiện lợi và xanh sạch nhất. Chỉ cần mở điện thoại, quét mã và bắt đầu hành trình của bạn với chi phí chưa tới một ly trà đá.")
            </p>

            <a href="/Account/Login" class="btn-aurora rounded-pill px-5 py-3 fs-5 shadow-lg fade-in-up delay-2">
                @(isEnglish ? "Start Riding Now" : "Bắt đầu ngay") <i class="bi bi-arrow-right-circle-fill ms-2"></i>
            </a>
        </div>
    </div>

    <form id="langForm" asp-controller="Language" asp-action="SetLanguage" method="post" class="d-none">
        <input type="hidden" name="returnUrl" value="/" />
        <input type="hidden" name="culture" id="cultureInput" value="" />
    </form>

    <script>
        function switchLanguage(lang) {
            document.getElementById('cultureInput').value = lang;
            document.getElementById('langForm').submit();
        }
    </script>
</body>
</html>