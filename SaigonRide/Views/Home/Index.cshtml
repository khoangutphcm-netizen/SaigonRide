﻿@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model IEnumerable<SaigonRide.Models.entities.RentalTransaction>
@{
    ViewData["Title"] = Localizer["DashboardTitle"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>  
    .announce-card-hover { transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); overflow: hidden; cursor: pointer; }
    .announce-card-hover:hover { transform: translateY(-4px); box-shadow: 0 12px 24px rgba(0,0,0,0.08) !important; border-color: #20994a !important; }
    .announce-img-wrapper { overflow: hidden; border-radius: 0.5rem; }
    .announce-img-wrapper img { transition: transform 0.4s ease; }
    .announce-card-hover:hover .announce-img-wrapper img { transform: scale(1.15); }
    .announce-title { transition: color 0.2s ease; }
    .announce-card-hover:hover .announce-title { color: #20994a !important; }
    .bg-grad-rent { background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%); }
    .bg-grad-history { background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%); }
    .bg-grad-support { background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%); }
    .bg-grad-settings { background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%); }
    .bg-grad-about { background: linear-gradient(135deg, #e0f7fa 0%, #e8f5e9 100%); }
    @@keyframes waveSpin { 100% { transform: translate(-50%, -50%) rotate(360deg); } }
    .electro-waves-container { position: absolute; top: 0; left: 0; width: 100%; height: 100%; overflow: hidden; pointer-events: none; }
    .electro-wave { position: absolute; top: 120%; left: 30%; width: 700px; height: 700px; background: transparent; border: 3px solid rgba(255, 255, 255, 0.4); border-radius: 43%; transform: translate(-50%, -50%); animation: waveSpin 8s linear infinite; box-shadow: 0 0 20px rgba(0, 255, 128, 0.6), inset 0 0 20px rgba(0, 255, 128, 0.6); }
    .electro-wave:nth-child(2) { top: 130%; border-radius: 38%; animation-duration: 12s; animation-direction: reverse; border-color: rgba(255, 255, 255, 0.2); box-shadow: 0 0 30px rgba(29, 233, 182, 0.4), inset 0 0 30px rgba(29, 233, 182, 0.4); }
    .electro-wave:nth-child(3) { top: 110%; width: 800px; height: 800px; border-radius: 46%; animation-duration: 15s; border-color: rgba(255, 255, 255, 0.15); box-shadow: 0 0 15px rgba(255, 255, 255, 0.3); }.electro-glow { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(circle at 30% 50%, rgba(255,255,255,0.25) 0%, transparent 60%); animation: electroPulse 1.5s infinite alternate; pointer-events: none; }
    body.dark-mode .bg-grad-rent { background: linear-gradient(135deg, #0a2916 0%, #144d29 100%); border: 1px solid #1b6335 !important; }
    body.dark-mode .bg-grad-history { background: linear-gradient(135deg, #0a243a 0%, #123e63 100%); border: 1px solid #1a568a !important; }
    body.dark-mode .bg-grad-support { background: linear-gradient(135deg, #3a250a 0%, #634012 100%); border: 1px solid #8f5c1a !important; }
    body.dark-mode .bg-grad-settings { background: linear-gradient(135deg, #2e1436 0%, #4c2258 100%); border: 1px solid #6c307d !important; }
    body.dark-mode .bg-grad-about { background: linear-gradient(135deg, #072226 0%, #0a2916 100%); border: 1px solid #104852 !important; }
    @@keyframes aurora-shift {
        0% {
            background-position: 0% 50%;
            box-shadow: 0 0 5px rgba(0, 255, 128, 0.6), 0 0 15px rgba(0, 255, 128, 0.4), 0 0 30px rgba(0, 200, 100, 0.2);
        }
        50% {
            background-position: 100% 50%;
            box-shadow: 0 0 15px rgba(64, 255, 128, 0.8), 0 0 30px rgba(64, 255, 128, 0.6), 0 0 50px rgba(0, 200, 100, 0.4);
        }
        100% {
            background-position: 0% 50%;
            box-shadow: 0 0 5px rgba(0, 255, 128, 0.6), 0 0 15px rgba(0, 255, 128, 0.4), 0 0 30px rgba(0, 200, 100, 0.2);
        }
    }

    .btn-aurora {
        background: linear-gradient(90deg, #00c853, #00e676, #1de9b6, #00e676, #00c853);
        background-size: 200% 100%;
        animation: aurora-shift 3s ease infinite;
        border: none;
        color: white;
        font-weight: bold;
        transition: all 0.3s ease;
        position: relative;
        z-index: 1;
        overflow: hidden;
    }

    .btn-aurora:hover {
        transform: scale(1.02);
        box-shadow: 0 0 20px rgba(0, 255, 128, 0.9);
        animation-duration: 1.5s;
    }
     
    .btn-aurora::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.5);
        transform: translate(-50%, -50%);
        transition: width 0.3s, height 0.3s;
        z-index: -1;
    }

    .btn-aurora:active::after {
        width: 200%;
        height: 200%;
        transition: 0s;
    }
     
    .rounded-4 { border-radius: 1rem !important; }
    
    .action-card { 
        border-radius: 1rem; 
        padding: 1.5rem; 
        text-align: center;
        transition: all 0.3s ease; 
        height: 100%; 
        display: flex; 
        flex-direction: column; 
    }
    
    .action-card:hover { 
        transform: translateY(-5px); 
        box-shadow: 0 12px 24px rgba(0,0,0,0.1) !important;
    }
    
    .icon-wrapper { 
        width: 60px; height: 60px;
        border-radius: 50%; 
        display: flex; align-items: center; justify-content: center; 
        margin: 0 auto 1rem auto;
    }
    
    .list-item-custom { border-bottom: 1px solid #f0f0f0; padding: 1rem 0; display: flex; align-items: center; }
    .list-item-custom:last-child { border-bottom: none; }
    
    .promo-banner { background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%); border-radius: 1rem; position: relative; overflow: hidden; padding: 2rem; border: 1px solid #a5d6a7; }
    
    .dark-mode .list-item-custom { border-color: #333; }
    .dark-mode .promo-banner { background: linear-gradient(135deg, #0a1f12 0%, #143621 100%); border-color: #1b5e38; }
    .rounded-4 { border-radius: 1rem !important; }
    
    .action-card { border-radius: 1.25rem; padding: 1.8rem 1.5rem; text-align: center; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); height: 100%; display: flex; flex-direction: column; border: 1px solid rgba(255,255,255,0.6) !important; position: relative; overflow: hidden; z-index: 1; }
    .action-card:hover { transform: translateY(-8px); box-shadow: 0 15px 30px rgba(0,0,0,0.08) !important; }
    
    .icon-wrapper { width: 65px; height: 65px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.2rem auto; box-shadow: 0 8px 16px rgba(0,0,0,0.06) !important; transition: transform 0.3s ease; }
    .action-card:hover .icon-wrapper { transform: scale(1.1) rotate(5deg); }
    
    .action-card .bg-icon { 
            position: absolute; 
            font-size: 8.5rem; 
            right: -15px; 
            bottom: -20px; 
            opacity: 0.25; /* Đậm hơn để sếp nhìn cho rõ */
            transition: all 0.4s ease;
    .action-card:hover .bg-icon { 
            transform: scale(1.15) rotate(-12deg); 
            opacity: 0.45; 
        }
/* Thêm icon phụ ở góc trái */
    .action-deco-mini {
        position: absolute;
        top: 15px;
        left: 15px;
        opacity: 0.12;
        font-size: 1.5rem;
        z-index: 0;
        transition: all 0.3s ease;
    }
    .action-card:hover .action-deco-mini {
        transform: scale(1.3) rotate(15deg);
        opacity: 0.25;
    }
    
    /* Hiệu ứng viền sáng chìm */
    .action-card::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle, rgba(255,255,255,0.4) 0%, transparent 70%);
        opacity: 0;
        transition: opacity 0.4s;
        z-index: 0;
    }
    .action-card:hover::before { opacity: 1; }
    .list-item-custom { border-bottom: 1px solid #f0f0f0; padding: 1rem; display: flex; align-items: center; transition: all 0.2s ease; border-radius: 0.75rem; margin-bottom: 0.25rem; }
    .list-item-custom:hover { background-color: #f8f9fa; transform: translateX(5px); }
    .list-item-custom:last-child { border-bottom: none; margin-bottom: 0; }
    
    .dark-mode .list-item-custom { border-color: #333; }
    .dark-mode .list-item-custom:hover { background-color: #1e1e1e; }
    .promo-banner { background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%); border-radius: 1rem; position: relative; overflow: hidden; padding: 2rem; border: 1px solid #a5d6a7; }
    .dark-mode .promo-banner { background: linear-gradient(135deg, #0a1f12 0%, #143621 100%); border-color: #1b5e38; }
</style>

<div class="container-fluid px-0">
     
    <div class="mb-4">
        <h3 class="fw-bold text-dark mb-1">@Localizer["Greeting", User.Identity.Name] <i class="bi bi-emoji-smile text-success"></i></h3>
        <p class="text-muted">@Localizer["GreetingSubtitle"]</p>
    </div>

    <div class="card border-0 rounded-4 shadow-sm mb-4 text-white overflow-hidden position-relative" 
         style="min-height: 250px; background-image: url('/images/banner.jpg'); background-size: cover; background-position: center right;">
    
        <div class="position-absolute top-0 start-0 h-100 z-0 overflow-hidden" style="width: 70%; background: linear-gradient(90deg, rgba(0, 200, 83, 0.95) 0%, rgba(17, 64, 71, 0.7) 60%, rgba(17, 64, 71, 0) 100%); pointer-events: none;">
            <div class="electro-waves-container">
                <div class="electro-wave"></div>
                <div class="electro-wave"></div>
                <div class="electro-wave"></div>
            </div>
        </div>

        <div class="card-body p-3 p-md-4 position-relative z-1 d-flex align-items-center h-100">
            <div class="z-1 position-relative p-4" style="max-width: 65%;">
            
                <span id="dynamic-station-badge" class="badge bg-white text-success rounded-pill mb-3 px-3 py-2 shadow-sm" style="display: none;">
                    <i class="bi bi-geo-alt-fill me-1"></i> <span id="station-name-text">@Localizer["FindingNearestStation"]</span>
                </span>
            
                <h3 class="fw-bold mb-2 text-white" style="text-shadow: 0 1px 3px rgba(0,0,0,0.3);">@Localizer["ReadyToRideTitle"]</h3>
                <p class="mb-4 fw-medium" style="color: rgba(255, 255, 255, 0.95); font-size: 1.05rem; text-shadow: 0 1px 2px rgba(0,0,0,0.3);">@Localizer["ReadyToRideDesc"]</p>
            
                <a asp-controller="Booking" asp-action="Index" class="btn btn-aurora rounded-pill px-5 py-3 fs-5 fw-bold shadow-lg">
                    @Localizer["RentNow"] <i class="bi bi-arrow-right-circle ms-1"></i>
                </a>
            </div>
        </div>
    </div>
    <div class="row g-4 mb-4 align-items-stretch">
        
        <div class="col-lg-8">
            <div class="row g-4 h-100">
                <div class="col-md-6">
                    <div class="action-card shadow-sm bg-grad-rent">
                        <div class="icon-wrapper bg-white text-success"><i class="bi bi-bicycle fs-2"></i></div>
                        <h5 class="fw-bold text-dark mb-2">@Localizer["RentVehicles"]</h5>
                        <p class="text-muted small mb-4 flex-grow-1 px-2">@Localizer["RentVehiclesDesc"]</p>
                        <a asp-controller="Booking" asp-action="Index" class="btn btn-success rounded-pill fw-bold w-100 py-2 shadow-sm d-flex justify-content-center align-items-center gap-2">@Localizer["RentNow"] <i class="bi bi-arrow-right"></i></a>
                        
                        <i class="bi bi-bicycle bg-icon text-success"></i>
                        <i class="bi bi-plus-circle-fill action-deco-mini text-success"></i>
                    </div>
                </div>
                
                <div class="col-md-6">
                    <div class="action-card shadow-sm bg-grad-history">
                        <div class="icon-wrapper bg-white text-primary"><i class="bi bi-clock-history fs-2"></i></div>
                        <h5 class="fw-bold text-dark mb-2">@Localizer["History"]</h5>
                        <p class="text-muted small mb-4 flex-grow-1 px-2">@Localizer["HistoryDesc"]</p>
                        <a asp-controller="History" asp-action="Index" class="btn btn-primary rounded-pill fw-bold w-100 py-2 shadow-sm d-flex justify-content-center align-items-center gap-2">@Localizer["ViewHistory"] <i class="bi bi-arrow-right"></i></a>
                        
                        <i class="bi bi-journal-text bg-icon text-primary"></i>
                        <i class="bi bi-clock-fill action-deco-mini text-primary"></i>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="action-card shadow-sm bg-grad-support">
                        <div class="icon-wrapper bg-white text-warning"><i class="bi bi-headset fs-2"></i></div>
                        <h5 class="fw-bold text-dark mb-2">@Localizer["Support"]</h5>
                        <p class="text-muted small mb-4 flex-grow-1 px-2">@Localizer["SupportDesc"]</p>
                        <a asp-controller="Profile" asp-action="Support" class="btn btn-warning text-dark rounded-pill fw-bold w-100 py-2 shadow-sm d-flex justify-content-center align-items-center gap-2">@Localizer["ContactUs"] <i class="bi bi-arrow-right"></i></a>
                        
                        <i class="bi bi-chat-dots bg-icon text-warning"></i>
                        <i class="bi bi-question-circle-fill action-deco-mini text-warning"></i>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="action-card shadow-sm bg-grad-settings">
                        <div class="icon-wrapper bg-white" style="color: #8e24aa;"><i class="bi bi-gear fs-2"></i></div>
                        <h5 class="fw-bold text-dark mb-2">@Localizer["Settings"]</h5>
                        <p class="text-muted small mb-4 flex-grow-1 px-2">@Localizer["SettingsDesc"]</p>
                        <a asp-controller="Profile" asp-action="Index" class="btn text-white rounded-pill fw-bold w-100 py-2 shadow-sm d-flex justify-content-center align-items-center gap-2" style="background-color: #8e24aa;">@Localizer["GoToSettings"] <i class="bi bi-arrow-right"></i></a>
                        
                        <i class="bi bi-sliders bg-icon" style="color: #8e24aa;"></i>
                        <i class="bi bi-nut-fill action-deco-mini" style="color: #8e24aa;"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 d-flex">
            <div class="card bg-white border-0 shadow-sm rounded-4 flex-grow-1 w-100 overflow-hidden">
                <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center pt-4 pb-3 px-4">
                    <h6 class="fw-bold text-dark mb-0 d-flex align-items-center gap-2"><i class="bi bi-stars text-warning fs-5"></i> @Localizer["Announcements"]</h6>
                    <a href="/Home/Announcements" class="text-success text-decoration-none small fw-bold">@Localizer["ViewAll"] <i class="bi bi-arrow-right"></i></a>
                </div>
                
                <div class="card-body px-3 pt-0 pb-3" style="overflow-y: auto; max-height: 480px;">
                    @if (ViewBag.Announcements != null)
                    {
                        foreach (var item in ViewBag.Announcements)
                        {
                            <a href="/Home/Announcements" class="text-decoration-none">
                                <div class="list-item-custom p-2 rounded-3 mb-3 d-flex align-items-center bg-white shadow-sm border announce-card-hover">
                                    
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <div class="announce-img-wrapper me-3 shadow-sm" style="width: 75px; height: 75px; flex-shrink: 0;">
                                            <img src="@item.ImageUrl" class="w-100 h-100" style="object-fit: cover;" />
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="bg-light p-3 text-success me-3 shadow-sm d-flex align-items-center justify-content-center announce-img-wrapper" style="width: 75px; height: 75px; flex-shrink: 0; font-size: 1.8rem;"><i class="bi bi-megaphone-fill"></i></div>
                                    }
                                    
                                    <div class="flex-grow-1 overflow-hidden pe-1">
                                        <div class="d-flex justify-content-between align-items-start mb-1">
                                            <h6 class="fw-bold text-dark mb-0 text-truncate announce-title" style="font-size: 0.95rem;">@item.Title</h6>
                                        </div>
                                        <p class="text-muted mb-1" style="font-size: 0.8rem; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@item.Content</p>
                                        <div class="d-flex justify-content-between align-items-center mt-1">
                                            <small class="text-secondary fw-medium" style="font-size: 0.7rem;"><i class="bi bi-clock me-1"></i> @item.CreatedAt.ToString("dd/MM/yyyy")</small>
                                            @if ((DateTime.Now - item.CreatedAt).TotalDays <= 3)
                                            {
                                                <span class="badge bg-danger rounded-pill" style="font-size: 0.6rem; padding: 0.2rem 0.5rem;">@Localizer["New"]</span>
                                            }
                                        </div>
                                    </div>
                                    
                                </div>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted small py-5 d-flex flex-column align-items-center">
                            <i class="bi bi-inbox fs-1 text-light mb-2"></i>
                            <span>@Localizer["NoAnnouncements"]</span>
                        </div>
                    }
                
                </div>
            </div>
        </div>

    </div>

    <div class="row g-4 mb-4 align-items-stretch">
        
    <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden position-relative h-100"
                 style="min-height: 100px; background-image: url('/images/promo.png'); background-size: cover; background-position: center right;">
                
                <div class="position-absolute top-0 start-0 w-100 h-100 z-0" style="background: linear-gradient(90deg, rgba(0, 0, 0, 0.5) 0%, rgba(0, 0, 0, 0) 100%); pointer-events: none;"></div>

                <div class="card-body p-3 d-flex flex-row align-items-center h-100 z-1 position-relative">
                    <div class="text-start" style="max-width: 85%;">
                        <div class="d-flex align-items-center mb-1">
                            <i class="bi bi-stars text-warning me-2" style="font-size: 1.1rem;"></i>
                            <h6 class="fw-bold text-white mb-0" style="letter-spacing: 0.3px; text-shadow: 0 1px 4px rgba(0,0,0,0.6);">@Localizer["BannerTitle"]</h6>
                        </div>
                        <p class="mb-0 mt-1 fw-medium" style="color: rgba(255, 255, 255, 0.95); font-size: 0.8rem; line-height: 1.35; text-shadow: 0 1px 4px rgba(0,0,0,0.6);">
                            @Localizer["BannerDesc"]
                        </p>
                    </div>
                </div>
            </div>
        </div>

    <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden position-relative h-100" 
                 style="min-height: 180px; background-image: linear-gradient(to right, rgba(10, 46, 15, 0.95) 0%, rgba(10, 46, 15, 0) 70%), url('/images/hiring.png'); background-size: cover; background-position: center right; color: white;">
                
                <div class="card-body p-4 position-relative z-1 d-flex flex-column justify-content-center">
                    
                    <div style="max-width: 55%;"> 
                        <h5 class="fw-bold mb-1">@Html.Raw(Localizer["JoinUsTitle"].Value)</h5>
                        <p class="mb-3" style="color: rgba(255,255,255,0.85); font-size: 0.85rem;">@Localizer["JoinUsDesc"]</p>
                        
                        <a href="mailto:contact@saigonride.com" class="btn btn-light text-success fw-bold rounded-pill px-3 py-2 shadow-sm" style="font-size: 0.85rem;">
                            @Localizer["EmailUs"] <i class="bi bi-envelope-paper ms-1"></i>
                        </a>
                    </div>

                </div>
            </div>
        </div>

    </div>
    <script>
    document.addEventListener("DOMContentLoaded", function() { 
        var stationData = JSON.parse('@Html.Raw(ViewBag.StationsJson)');
         
        if (navigator.geolocation && stationData.length > 0) {
            navigator.geolocation.getCurrentPosition(function (position) {
                var userLat = position.coords.latitude;
                var userLng = position.coords.longitude;
                 
                function calcDist(lat1, lon1, lat2, lon2) {
                    var R = 6371;
                    var dLat = (lat2 - lat1) * Math.PI / 180;
                    var dLon = (lon2 - lon1) * Math.PI / 180;
                    var a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
                            Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
                            Math.sin(dLon / 2) * Math.sin(dLon / 2);
                    var c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
                    return R * c;
                }

                let closest = null;
                let minDistance = Infinity;
                 
                stationData.forEach(st => {
                    if (st.lat && st.lng) {
                        let dist = calcDist(userLat, userLng, st.lat, st.lng);
                        if (dist < minDistance) {
                            minDistance = dist;
                            closest = st;
                        }
                    }
                });
                 
                
                    if (closest) {
                        let distText = minDistance < 1 ? (minDistance * 1000).toFixed(0) + " m" : minDistance.toFixed(1) + " km";
                         
                        let formatString = '@Html.Raw(Localizer["NearestStationFormat"].Value)';
                        let finalText = formatString.replace('{0}', closest.name).replace('{1}', distText);
                         
                        document.getElementById('station-name-text').innerText = finalText;
                         
                        let badge = document.getElementById('dynamic-station-badge');
                        if(badge) badge.style.display = 'inline-block';
                    }
                }
            });
        }
    });
</script>