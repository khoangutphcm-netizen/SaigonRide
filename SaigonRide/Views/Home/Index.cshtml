﻿﻿@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model IEnumerable<SaigonRide.Models.entities.RentalTransaction>
@{
    ViewData["Title"] = Localizer["DashboardTitle"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>  
    .bg-grad-rent { background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%); }
    .bg-grad-history { background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%); }
    .bg-grad-support { background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%); }
    .bg-grad-settings { background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%); }
    .bg-grad-about { background: linear-gradient(135deg, #e0f7fa 0%, #e8f5e9 100%); }

    /* Khi body có class dark-mode, tự động ghi đè dải màu siêu ngầu */
    body.dark-mode .bg-grad-rent { background: linear-gradient(135deg, #0a2916 0%, #144d29 100%); border: 1px solid #1b6335 !important; }
    body.dark-mode .bg-grad-history { background: linear-gradient(135deg, #0a243a 0%, #123e63 100%); border: 1px solid #1a568a !important; }
    body.dark-mode .bg-grad-support { background: linear-gradient(135deg, #3a250a 0%, #634012 100%); border: 1px solid #8f5c1a !important; }
    body.dark-mode .bg-grad-settings { background: linear-gradient(135deg, #2e1436 0%, #4c2258 100%); border: 1px solid #6c307d !important; }
    body.dark-mode .bg-grad-about { background: linear-gradient(135deg, #072226 0%, #0a2916 100%); border: 1px solid #104852 !important; }
    @@keyframes aurora-shift {
        0% {
            background-position: 0% 50%;
            box-shadow: 0 0 5px rgba(0, 255, 128, 0.6), 0 0 15px rgba(0, 255, 128, 0.4), 0 0 30px rgba(0, 200, 100, 0.2);
        }
        50% {
            background-position: 100% 50%;
            box-shadow: 0 0 15px rgba(64, 255, 128, 0.8), 0 0 30px rgba(64, 255, 128, 0.6), 0 0 50px rgba(0, 200, 100, 0.4);
        }
        100% {
            background-position: 0% 50%;
            box-shadow: 0 0 5px rgba(0, 255, 128, 0.6), 0 0 15px rgba(0, 255, 128, 0.4), 0 0 30px rgba(0, 200, 100, 0.2);
        }
    }

    .btn-aurora {
        background: linear-gradient(90deg, #00c853, #00e676, #1de9b6, #00e676, #00c853);
        background-size: 200% 100%;
        animation: aurora-shift 3s ease infinite;
        border: none;
        color: white;
        font-weight: bold;
        transition: all 0.3s ease;
        position: relative;
        z-index: 1;
        overflow: hidden;
    }

    .btn-aurora:hover {
        transform: scale(1.02);
        box-shadow: 0 0 20px rgba(0, 255, 128, 0.9);
        animation-duration: 1.5s;
    }
     
    .btn-aurora::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.5);
        transform: translate(-50%, -50%);
        transition: width 0.3s, height 0.3s;
        z-index: -1;
    }

    .btn-aurora:active::after {
        width: 200%;
        height: 200%;
        transition: 0s;
    }
     
    .rounded-4 { border-radius: 1rem !important; }
    
    .action-card { 
        border-radius: 1rem; 
        padding: 1.5rem; 
        text-align: center;
        transition: all 0.3s ease; 
        height: 100%; 
        display: flex; 
        flex-direction: column; 
    }
    
    .action-card:hover { 
        transform: translateY(-5px); 
        box-shadow: 0 12px 24px rgba(0,0,0,0.1) !important;
    }
    
    .icon-wrapper { 
        width: 60px; height: 60px;
        border-radius: 50%; 
        display: flex; align-items: center; justify-content: center; 
        margin: 0 auto 1rem auto;
    }
    
    .list-item-custom { border-bottom: 1px solid #f0f0f0; padding: 1rem 0; display: flex; align-items: center; }
    .list-item-custom:last-child { border-bottom: none; }
    
    .promo-banner { background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%); border-radius: 1rem; position: relative; overflow: hidden; padding: 2rem; border: 1px solid #a5d6a7; }
    
    .dark-mode .list-item-custom { border-color: #333; }
    .dark-mode .promo-banner { background: linear-gradient(135deg, #0a1f12 0%, #143621 100%); border-color: #1b5e38; }
</style>

<div class="container-fluid px-0">
     
    <div class="mb-4">
        <h3 class="fw-bold text-dark mb-1">@Localizer["Greeting", User.Identity.Name] <i class="bi bi-emoji-smile text-success"></i></h3>
        <p class="text-muted">@Localizer["GreetingSubtitle"]</p>
    </div>

    <div class="card border-0 rounded-4 shadow-lg mb-4 text-white overflow-hidden" 
         style="background-image: linear-gradient(90deg, rgba(0, 200, 83, 0.98) 35%, rgba(17, 71, 40, 0.1) 100%), url('/images/banner.jpg'); background-size: cover; background-position: center right;">
        <div class="card-body p-4 p-md-5 position-relative">
            <div class="z-1 position-relative" style="max-width: 65%;">
                <span id="dynamic-station-badge" class="badge bg-white text-success rounded-pill mb-3 px-3 py-2 shadow-sm" style="display: none;">
                    <i class="bi bi-geo-alt-fill me-1"></i> <span id="station-name-text">@Localizer["FindingNearestStation"]</span>
                </span>
                <h2 class="fw-bold mb-3 display-6 text-white">@Localizer["ReadyToRideTitle"]</h2>
                <p class="mb-4 opacity-75 fs-5">@Localizer["ReadyToRideDesc"]</p>
                <a asp-controller="Booking" asp-action="Index" class="btn btn-aurora btn-lg rounded-pill px-5 py-3 fw-bold fs-5 shadow">@Localizer["RentNow"] <i class="bi bi-arrow-right-circle ms-2"></i></a>
            </div>
            </div>
    </div>
    <div class="row g-4 mb-4 align-items-stretch">
        
        <div class="col-lg-8">
            <div class="row g-4 h-100">
                <div class="col-md-6">
                    <div class="action-card shadow-sm border-0 position-relative overflow-hidden bg-grad-rent">
                        <div class="icon-wrapper bg-white text-success shadow-sm position-relative z-1"><i class="bi bi-bicycle fs-2"></i></div>
                        <h6 class="fw-bold text-dark position-relative z-1">@Localizer["RentVehicles"]</h6>
                        <p class="text-muted small mb-3 flex-grow-1 position-relative z-1">@Localizer["RentVehiclesDesc"]</p> 
                        <a asp-controller="Booking" asp-action="Index" class="btn btn-success rounded-pill fw-bold w-100 py-2 position-relative z-1 shadow-sm">@Localizer["RentNow"] <i class="bi bi-arrow-right ms-1"></i></a>
                        <i class="bi bi-bicycle position-absolute opacity-10" style="font-size: 8rem; right: -20px; bottom: -20px; transform: rotate(-15deg);"></i>
                    </div>
                </div>
                
                <div class="col-md-6">
                    <div class="action-card shadow-sm border-0 position-relative overflow-hidden bg-grad-history">
                        <div class="icon-wrapper bg-white text-primary shadow-sm position-relative z-1"><i class="bi bi-clock-history fs-2"></i></div>
                        <h6 class="fw-bold text-dark position-relative z-1">@Localizer["History"]</h6>
                        <p class="text-muted small mb-3 flex-grow-1 position-relative z-1">@Localizer["HistoryDesc"]</p>
                        <a asp-controller="History" asp-action="Index" class="btn btn-primary rounded-pill fw-bold w-100 position-relative z-1">@Localizer["ViewHistory"] <i class="bi bi-arrow-right ms-1"></i></a>
                        <i class="bi bi-journal-text position-absolute opacity-10" style="font-size: 8rem; right: -20px; bottom: -20px; transform: rotate(10deg);"></i>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="action-card shadow-sm border-0 position-relative overflow-hidden bg-grad-support">
                        <div class="icon-wrapper bg-white text-warning shadow-sm position-relative z-1"><i class="bi bi-headset fs-2"></i></div>
                        <h6 class="fw-bold text-dark position-relative z-1">@Localizer["Support"]</h6>
                        <p class="text-muted small mb-3 flex-grow-1 position-relative z-1">@Localizer["SupportDesc"]</p>
                        <a asp-controller="Profile" asp-action="Support" class="btn btn-warning text-dark rounded-pill fw-bold w-100 position-relative z-1">@Localizer["ContactUs"] <i class="bi bi-arrow-right ms-1"></i></a>
                        <i class="bi bi-chat-dots position-absolute opacity-10" style="font-size: 8rem; right: -20px; bottom: -20px; transform: rotate(-10deg);"></i>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="action-card shadow-sm border-0 position-relative overflow-hidden bg-grad-settings">
                        <div class="icon-wrapper bg-white shadow-sm position-relative z-1" style="color: #8e24aa;"><i class="bi bi-gear fs-2"></i></div>
                        <h6 class="fw-bold text-dark position-relative z-1">@Localizer["Settings"]</h6>
                        <p class="text-muted small mb-3 flex-grow-1 position-relative z-1">@Localizer["SettingsDesc"]</p>
                        <a asp-controller="Profile" asp-action="Index" class="btn text-white rounded-pill fw-bold w-100 position-relative z-1" style="background-color: #8e24aa;">@Localizer["GoToSettings"] <i class="bi bi-arrow-right ms-1"></i></a>
                        <i class="bi bi-sliders position-absolute opacity-10" style="font-size: 8rem; right: -20px; bottom: -20px; transform: rotate(15deg);"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4 d-flex">
            <div class="card bg-white border-0 shadow-sm rounded-4 flex-grow-1 w-100">
                <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center pt-4 pb-2 px-4">
                    <h6 class="fw-bold text-dark mb-0"><i class="bi bi-megaphone-fill text-success me-2"></i> @Localizer["Announcements"]</h6>
                    <a href="/Home/Announcements" class="text-success text-decoration-none small fw-bold">@Localizer["ViewAll"]</a>
                </div>
                <div class="card-body px-4 pt-0" style="overflow-y: auto; max-height: 480px;">
                    @if (ViewBag.Announcements != null)
                    {
                        foreach (var item in ViewBag.Announcements)
                        {
                            <div class="list-item-custom border-bottom border-light py-3">
                                <div class="bg-success bg-opacity-10 p-2 rounded text-success me-3"><i class="bi bi-bell"></i></div>
                                <div>
                                    @if ((DateTime.Now - item.CreatedAt).TotalDays <= 3)
                                    {
                                        <span class="badge bg-success rounded-pill mb-1" style="font-size: 0.6rem;">@Localizer["New"]</span>
                                    }
                                    <h6 class="fw-bold text-dark mb-1" style="font-size: 0.85rem;">@item.Title</h6>
                                    <p class="text-muted mb-1" style="font-size: 0.75rem;">@item.Content</p>
                                    <small class="text-muted" style="font-size: 0.7rem;">@item.CreatedAt.ToString("dd MMM yyyy")</small>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted small py-4">@Localizer["NoAnnouncements"]</div>
                    }
                </div>
            </div>
        </div>

    </div>

    <div class="row g-4 mb-4 align-items-stretch">
        
    <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden position-relative h-100" 
                 style="min-height: 200px; background-image: linear-gradient(to right, rgba(232, 245, 233, 0.95) 30%, rgba(232, 245, 233, 0.4) 100%), url('/images/promo.png'); background-size: cover; background-position: center;">
                <div class="card-body p-4 position-relative z-1 d-flex align-items-center">
                    <div style="max-width: 75%;">
                        <div class="d-flex align-items-center mb-2">
                            <i class="bi bi-tree-fill text-success fs-3 me-2"></i>
                            <h4 class="fw-bold text-dark mb-0">@Localizer["BannerTitle"]</h4>
                        </div>
                        <p class="text-muted mb-0 fw-medium" style="font-size: 0.95rem; line-height: 1.5;">@Localizer["BannerDesc"]</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden position-relative h-100" 
                 style="min-height: 180px; background-image: linear-gradient(to right, rgba(10, 46, 25, 0.95) 10%, rgba(10, 46, 25, 0.3) 100%), url('/images/hiring.png'); background-size: cover; background-position: center; color: white;">
                <div class="card-body p-4 position-relative z-1 d-flex flex-column justify-content-center">
                    <div style="max-width: 80%;">
                        <h4 class="fw-bold mb-2">@Html.Raw(Localizer["JoinUsTitle"].Value)</h4>
                        <p class="small mb-3" style="color: rgba(255,255,255,0.8);">@Localizer["JoinUsDesc"]</p>
                        <a href="mailto:contact@saigonride.com" class="btn btn-light text-success fw-bold rounded-pill px-4 py-2 btn-sm shadow-sm">
                            @Localizer["EmailUs"] <i class="bi bi-envelope-paper ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

    </div>
    <script>
    document.addEventListener("DOMContentLoaded", function() {
        // Lấy dữ liệu trạm từ Controller
        var stationData = JSON.parse('@Html.Raw(ViewBag.StationsJson)');
        
        // Kiểm tra xem trình duyệt có hỗ trợ định vị không 
        if (navigator.geolocation && stationData.length > 0) {
            navigator.geolocation.getCurrentPosition(function (position) {
                var userLat = position.coords.latitude;
                var userLng = position.coords.longitude;

                // Công thức tính khoảng cách 
                function calcDist(lat1, lon1, lat2, lon2) {
                    var R = 6371;
                    var dLat = (lat2 - lat1) * Math.PI / 180;
                    var dLon = (lon2 - lon1) * Math.PI / 180;
                    var a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
                            Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
                            Math.sin(dLon / 2) * Math.sin(dLon / 2);
                    var c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
                    return R * c;
                }

                let closest = null;
                let minDistance = Infinity;

                // Quét tìm trạm gần nhất [cite: 465, 466]
                stationData.forEach(st => {
                    if (st.lat && st.lng) {
                        let dist = calcDist(userLat, userLng, st.lat, st.lng);
                        if (dist < minDistance) {
                            minDistance = dist;
                            closest = st;
                        }
                    }
                });

                // Cập nhật giao diện Banner
                
                    if (closest) {
                        let distText = minDistance < 1 ? (minDistance * 1000).toFixed(0) + " m" : minDistance.toFixed(1) + " km";
                        
                        // Lấy chuỗi format từ Localizer và thay thế biến {0}, {1}
                        let formatString = '@Html.Raw(Localizer["NearestStationFormat"].Value)';
                        let finalText = formatString.replace('{0}', closest.name).replace('{1}', distText);
                        
                        // Thay thế text
                        document.getElementById('station-name-text').innerText = finalText;
                        
                        // Hiện cái badge lên
                        let badge = document.getElementById('dynamic-station-badge');
                        if(badge) badge.style.display = 'inline-block';
                    }
                }
            });
        }
    });
</script>