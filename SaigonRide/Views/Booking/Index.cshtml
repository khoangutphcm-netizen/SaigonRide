@model IEnumerable<SaigonRide.Models.entities.Station>
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{ ViewData["Title"] = Localizer["PageTitle"].Value; }

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.js"></script>

<style>
    .glass-card { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); border: none; border-radius: 1.5rem; }
    .vehicle-row { transition: all 0.2s; border-radius: 1rem; cursor: pointer; }
    .vehicle-row:hover { background: #f8f9fa; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(0,0,0,0.05); }
    .vehicle-img { width: 60px; height: 60px; background: #e9ecef; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 2rem; color: #198754; }
    #mainMap { height: calc(100vh - 80px); border-radius: 1.5rem; } 
    .leaflet-routing-container { display: none !important; }
</style>

<div class="container-fluid py-3">
    <div class="row g-3">
        <div class="col-lg-5 col-xl-4 d-flex flex-column gap-3 h-100">
            <div class="glass-card shadow-sm p-4">
                <h3 class="fw-bold text-dark mb-1">@Localizer["PageTitle"] <i class="bi bi-geo-alt-fill text-success"></i></h3>
                <p class="text-muted small mb-4">@Localizer["PageSubtitle"]</p>
                
                <div class="position-relative mb-3">
                    <i class="bi bi-search position-absolute text-muted" style="top: 50%; transform: translateY(-50%); left: 15px;"></i>
                    <input type="text" id="vehicleSearch" class="form-control form-control-lg rounded-pill ps-5 bg-light border-0 shadow-none" placeholder="@Localizer["SearchPlaceholder"]" onkeyup="filterVehicles()">
                </div>
            </div>

            <div class="glass-card shadow-sm p-4 flex-grow-1 overflow-auto" style="max-height: calc(100vh - 280px);">
                <div id="stationInfoPanel" class="mb-3">
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-map fs-1 d-block mb-3 opacity-25 text-success"></i>
                        <p>@Localizer["SelectStationPrompt"]</p>
                    </div>
                </div>
                <div id="vehicleListContainer" class="d-flex flex-column gap-2"></div>
            </div>
        </div>

        <div class="col-lg-7 col-xl-8">
            <div class="card border-0 shadow-sm rounded-4 bg-white p-1">
                <div id="mainMap" class="w-100"></div>
            </div>
        </div>
    </div>
</div>
<script>
    var map = L.map('mainMap', { zoomControl: false }).setView([10.785, 106.705], 14);
    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
    L.control.zoom({ position: 'bottomright' }).addTo(map);

    var stationData = JSON.parse('@Html.Raw(ViewBag.StationsJson)');
    var currentStation = null;
    var routingControl = null;
    var userLatLng = null; 
    var stationMarkers = {};

    var userIcon = L.divIcon({ 
        className: 'custom-div-icon', 
        html: `<div class="bg-primary text-white rounded-circle shadow-lg border border-4 border-white d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;"><i class="bi bi-person-fill fs-5"></i></div>`, 
        iconSize: [40, 40],
        iconAnchor: [20, 20]
    });

    function createStationIcon(isEmpty) {
        var iconHtml = isEmpty ? 
            `<div class="bg-white rounded-circle shadow-lg border border-3 border-secondary d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;"><i class="bi bi-geo-alt-fill text-secondary fs-4"></i></div>` : 
            `<div class="bg-white rounded-circle shadow-lg border border-3 border-success d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;"><i class="bi bi-geo-alt-fill text-success fs-4"></i></div>`;
        return L.divIcon({ className: 'custom-div-icon', html: iconHtml, iconSize: [45, 45], iconAnchor: [22, 45] });
    }

    stationData.forEach(function (st) {
        if(st.lat && st.lng) { 
            var marker = L.marker([st.lat, st.lng], { icon: createStationIcon(st.inventory <= 0) }).addTo(map);
            marker.bindTooltip(`<b>${st.name}</b><br>${st.inventory} @Localizer["Available"]`, { direction: 'top', offset: [0, -45] });
            
            marker.on('click', function () {
                currentStation = st; 
                renderStationDetailAndVehicles(st);
                drawRouteToStation(st.lat, st.lng);  
            });
            stationMarkers[st.id] = marker;
        }
    }); 

    if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(function (position) {
            userLatLng = L.latLng(position.coords.latitude, position.coords.longitude);
            L.marker(userLatLng, { icon: userIcon }).addTo(map).bindTooltip("@Localizer["YourLocation"]").openTooltip();
            map.setView(userLatLng, 15);
        });
    } 

    function drawRouteToStation(destLat, destLng) {
        if (!userLatLng) return;
        if (routingControl) map.removeControl(routingControl); 
        
        var destLatLng = L.latLng(destLat, destLng);

        routingControl = L.Routing.control({
            waypoints: [userLatLng, destLatLng],
            routeWhileDragging: false, addWaypoints: false, show: false,
            createMarker: function() { return null; },  
            lineOptions: { styles: [{color: '#0d6efd', opacity: 0.8, weight: 6, dashArray: '10, 10'}] }  
        }).addTo(map);
        var bounds = L.latLngBounds([userLatLng, destLatLng]);
        map.fitBounds(bounds, { padding: [60, 60], maxZoom: 16 });
    }

    function renderStationDetailAndVehicles(st) {
        let distHtml = "";
        if (userLatLng && st.lat && st.lng) {
            var R = 6371; 
            var dLat = (st.lat - userLatLng.lat) * Math.PI / 180; 
            var dLon = (st.lng - userLatLng.lng) * Math.PI / 180;
            var a = Math.sin(dLat/2) * Math.sin(dLat/2) + Math.cos(userLatLng.lat * Math.PI / 180) * Math.cos(st.lat * Math.PI / 180) * Math.sin(dLon/2) * Math.sin(dLon/2);
            var distKm = R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
            var distText = distKm < 1 ? (distKm * 1000).toFixed(0) + " m" : distKm.toFixed(1) + " km";
            distHtml = `<span class="badge bg-primary bg-opacity-10 text-primary rounded-pill ms-2"><i class="bi bi-cursor-fill me-1"></i>${distText}</span>`;
        }

        document.getElementById('stationInfoPanel').innerHTML = `
            <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
                <div class="d-flex align-items-center">
                    <h5 class="fw-bold text-dark mb-0">${st.name}</h5>
                    ${distHtml}
                </div>
                <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2"><i class="bi bi-check-circle me-1"></i>@Localizer["Open"]</span>
            </div>
            <div class="row text-center mb-3">
                <div class="col-6 border-end">
                    <h4 class="fw-bold text-dark mb-0">${st.capacity}</h4>
                    <small class="text-muted">@Localizer["Capacity"]</small>
                </div>
                <div class="col-6">
                    <h4 class="fw-bold text-success mb-0">${st.inventory}</h4>
                    <small class="text-muted">@Localizer["Available"]</small>
                </div>
            </div>`;
        renderVehiclesList(st.vehicles);
    }

    function renderVehiclesList(vehiclesList) {
        var listContainer = document.getElementById('vehicleListContainer');
        var html = "";
        if (!vehiclesList || vehiclesList.length === 0) {
            html = `<div class="text-center py-4 text-muted"><p>@Localizer["NoVehicles"]</p></div>`;
        } else {
            vehiclesList.forEach(function (v) {
                var isScooter = v.name.toLowerCase().includes("scooter");
                html += `
                    <div class="vehicle-row border p-2 d-flex align-items-center mb-2" onclick="window.location.href='/Checkout/Rent?vehicleId=${v.id}'">
                        <div class="vehicle-img me-3"><i class="bi ${isScooter ? 'bi-scooter' : 'bi-bicycle'}"></i></div>
                        <div class="flex-grow-1">
                            <h6 class="fw-bold text-dark mb-0">${v.name}</h6>
                            <small class="text-muted">ID: SR-${v.id}</small>
                        </div>
                        <div class="text-end">
                            <h6 class="text-success fw-bold mb-0">${v.price.toLocaleString('vi-VN')}đ<small>/m</small></h6>
                            <small class="text-muted"><i class="bi bi-chevron-right"></i></small>
                        </div>
                    </div>`;
            });
        }
        listContainer.innerHTML = html;
    }

    window.filterVehicles = function() {
        if(!currentStation || !currentStation.vehicles) return;
        var keyword = document.getElementById('vehicleSearch').value.toLowerCase();
        var filtered = currentStation.vehicles.filter(v => v.name.toLowerCase().includes(keyword));
        renderVehiclesList(filtered);
    };

    function fetchLiveUserStations() {
        fetch('/Checkout/GetLiveStationsData').then(r => r.json()).then(data => {
            stationData = data;
            data.forEach(st => {
                let marker = stationMarkers[st.id];
                if (marker) {
                    marker.setIcon(createStationIcon(st.inventory <= 0));
                    marker.setTooltipContent(`<b>${st.name}</b><br>${st.inventory} @Localizer["Available"]`);
                }
                
                if (currentStation && currentStation.id === st.id) {
                    currentStation = st;
                    renderStationDetailAndVehicles(st);
                    filterVehicles(); 
                }
            });
        });
    }
    setInterval(fetchLiveUserStations, 5000);
</script>