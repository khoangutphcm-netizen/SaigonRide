@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["PageTitle"].Value;
}

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-md-8 col-lg-6">
        <div class="d-flex align-items-center mb-4 px-2">
            <a href="javascript:history.back()" class="btn btn-light rounded-circle me-3 shadow-sm text-dark"><i class="bi bi-arrow-left"></i></a>
            <div>
                <h4 class="fw-bold text-dark mb-0">@Localizer["PageTitle"]</h4>
                <small class="text-muted">@Localizer["PageSubtitle"]</small>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-sm-6">
                <a href="tel:19001000" class="card border-0 shadow-sm rounded-4 text-decoration-none text-center p-4 bg-white h-100 action-card">
                    <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex justify-content-center align-items-center mx-auto mb-3" style="width: 50px; height: 50px;"><i class="bi bi-telephone-fill fs-4"></i></div>
                    <h6 class="fw-bold text-dark mb-1">@Localizer["CallUs"]</h6>
                    <small class="text-muted">1900 1000</small>
                </a>
            </div>
            <div class="col-sm-6">
                <a href="mailto:support@saigonride.vn" class="card border-0 shadow-sm rounded-4 text-decoration-none text-center p-4 bg-white h-100 action-card">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex justify-content-center align-items-center mx-auto mb-3" style="width: 50px; height: 50px;"><i class="bi bi-envelope-fill fs-4"></i></div>
                    <h6 class="fw-bold text-dark mb-1">@Localizer["EmailUs"]</h6>
                    <small class="text-muted">support@saigonride.vn</small>
                </a>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 bg-white p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold text-dark mb-0"><i class="bi bi-chat-left-text-fill text-success me-2"></i> @Localizer["SendFeedback"]</h5>
                <a href="/Reports/MyReports" class="btn btn-sm btn-outline-success rounded-pill fw-bold"><i class="bi bi-clock-history me-1"></i> Báo cáo của tôi</a>
            </div>

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger shadow-sm rounded-3 border-0 mb-4 py-2">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
                </div>
            }

            <form asp-controller="Reports" asp-action="CreateReport" method="post">
                <div class="mb-3">
                    <label for="topic" class="form-label text-muted small fw-bold">@Localizer["LabelTopic"]</label>
                    <select id="topic" name="title" class="form-select form-select-lg border-light shadow-none bg-light fw-bold text-dark rounded-3" required>
                        <option value="">-- @Localizer["LabelTopic"] --</option>
                        <option value="Sự cố ứng dụng">@Localizer["Topic_AppIssue"]</option>
                        <option value="Vấn đề phương tiện">@Localizer["Topic_VehicleIssue"]</option>
                        <option value="Vấn đề thanh toán">@Localizer["Topic_Payment"]</option>
                        <option value="Khác">@Localizer["Topic_Other"]</option>
                    </select>
                </div>
                <div class="mb-4">
                    <label for="description" class="form-label text-muted small fw-bold">@Localizer["LabelMessage"]</label>
                    <textarea id="description" name="description" class="form-control border-light shadow-none bg-light rounded-3" rows="5" placeholder="@Localizer["MsgPlaceholder"]" required></textarea>
                </div>
                <input type="hidden" name="rentalTransactionId" value="0" />
                <button type="submit" class="btn btn-success w-100 py-3 rounded-pill fw-bold shadow-sm d-flex justify-content-center align-items-center gap-2" style="font-size: 1.05rem;">
                    @Localizer["BtnSubmit"] <i class="bi bi-send-fill"></i>
                </button>
            </form>
        </div>
    </div>
</div>