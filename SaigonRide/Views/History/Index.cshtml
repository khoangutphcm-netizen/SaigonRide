@model IEnumerable<SaigonRide.Models.entities.RentalTransaction>
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["PageTitle"].Value;
}

<style>
    .stat-card { border: none; border-radius: 1.2rem; padding: 1.5rem; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); box-shadow: 0 8px 20px rgba(0,0,0,0.05); transition: transform 0.2s; }
    .stat-card:hover { transform: translateY(-5px); }
    .stat-icon { width: 45px; height: 45px; border-radius: 12px; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%); color: #198754; font-size: 1.4rem; box-shadow: 0 4px 10px rgba(25, 135, 84, 0.2); }
    .history-row { display: flex; align-items: center; padding: 1.5rem; border-bottom: 1px solid #f0f0f0; transition: all 0.2s; border-radius: 1rem; margin-bottom: 0.5rem; }
    .history-row:hover { background-color: #f8fcf9; box-shadow: 0 5px 15px rgba(0,0,0,0.05); transform: scale(1.01); }
    .vehicle-img-placeholder { width: 65px; height: 65px; background: linear-gradient(135deg, #f4f6f8 0%, #e9ecef 100%); border-radius: 15px; display: flex; align-items: center; justify-content: center; font-size: 2.2rem; color: #198754; box-shadow: inset 0 2px 5px rgba(0,0,0,0.05); }
    body.dark-mode .stat-card { background: #212529; }
    body.dark-mode .history-row { border-color: #333; }
    body.dark-mode .history-row:hover { background-color: #1a1d20; }
    body.dark-mode .vehicle-img-placeholder { background: linear-gradient(135deg, #2a2d30 0%, #1a1d20 100%); color: #555; }
</style>

<div class="container-fluid py-4 px-0">
    <div class="d-flex align-items-center gap-3 mb-4 px-3">
        <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center shadow" style="width: 50px; height: 50px;">
            <i class="bi bi-clock-history fs-4"></i>
        </div>
        <div>
            <h3 class="fw-bold text-dark mb-0">@Localizer["PageTitle"]</h3>
            <p class="text-muted mb-0 small">@Localizer["PageSubtitle"]</p>
        </div>
    </div>

    <div class="row g-4 px-3 mb-5">
        @{
            var totalRides = Model?.Count() ?? 0;
            var totalMinutes = Model?.Sum(x => (x.EndTime.HasValue ? (x.EndTime.Value - x.StartTime).TotalMinutes : (DateTime.Now - x.StartTime).TotalMinutes)) ?? 0;
            var totalSpent = Model?.Sum(x => x.TotalDue) ?? 0;
            var totalDistanceKm = totalMinutes * 0.25;
            var co2SavedKg = totalMinutes * 0.05;
        }

        <div class="col-sm-6 col-lg-3">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="stat-icon"><i class="bi bi-signpost-split"></i></div>
                </div>
                <h3 class="fw-bold text-dark mb-0">@totalRides</h3>
                <small class="text-muted fw-bold">@Localizer["TotalRides"] <span class="fw-normal" style="font-size: 0.7rem;">(@Localizer["AllTime"])</span></small>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="stat-icon"><i class="bi bi-map"></i></div>
                </div>
                <h3 class="fw-bold text-dark mb-0">@totalDistanceKm.ToString("0.0") <span class="fs-6 text-muted">km</span></h3>
                <small class="text-muted fw-bold">@Localizer["TotalDistance"] <span class="fw-normal" style="font-size: 0.7rem;">(@Localizer["AllTime"])</span></small>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="stat-icon"><i class="bi bi-wallet2"></i></div>
                </div>
                <h3 class="fw-bold text-dark mb-0">@totalSpent.ToString("N0") <span class="fs-6 text-muted">đ</span></h3>
                <small class="text-muted fw-bold">@Localizer["TotalSpent"] <span class="fw-normal" style="font-size: 0.7rem;">(@Localizer["AllTime"])</span></small>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="stat-icon"><i class="bi bi-tree"></i></div>
                </div>
                <h3 class="fw-bold text-dark mb-0">@co2SavedKg.ToString("0.0") <span class="fs-6 text-muted">kg</span></h3>
                <small class="text-muted fw-bold">@Localizer["Co2Saved"] <span class="fw-normal" style="font-size: 0.7rem;">(@Localizer["AllTime"])</span></small>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-lg rounded-4 bg-white mx-3 overflow-hidden"> 
        <div class="card-header bg-light border-bottom d-flex flex-column flex-md-row justify-content-between align-items-md-center p-4 gap-3">
            <div class="d-flex gap-4">
                <a asp-action="Index" asp-route-type="all" asp-route-period="@ViewBag.ActivePeriod" 
                   class="fw-bold text-decoration-none pb-2 @(ViewBag.ActiveType == "all" ? "text-success border-bottom border-success border-3" : "text-muted")">
                   @Localizer["TabAll"]
                </a>
                <a asp-action="Index" asp-route-type="bike" asp-route-period="@ViewBag.ActivePeriod" 
                   class="fw-bold text-decoration-none pb-2 @(ViewBag.ActiveType == "bike" ? "text-success border-bottom border-success border-3" : "text-muted")">
                   @Localizer["TabBike"]
                </a>
                <a asp-action="Index" asp-route-type="scooter" asp-route-period="@ViewBag.ActivePeriod" 
                   class="fw-bold text-decoration-none pb-2 @(ViewBag.ActiveType == "scooter" ? "text-success border-bottom border-success border-3" : "text-muted")">
                   @Localizer["TabScooter"]
                </a>
            </div>
            
            <form method="get" asp-action="Index" class="d-flex gap-2 m-0 bg-white p-1 rounded-pill shadow-sm border">
                <input type="hidden" name="type" value="@ViewBag.ActiveType" />
                <select name="period" class="form-select form-select-sm border-0 shadow-none text-muted fw-bold bg-transparent pr-4" onchange="this.form.submit()" style="cursor: pointer;">
                    @if(ViewBag.ActivePeriod == "all"){ <option value="all" selected>@Localizer["FilterAllTime"]</option> } else { <option value="all">@Localizer["FilterAllTime"]</option> }
                    @if(ViewBag.ActivePeriod == "month"){ <option value="month" selected>@Localizer["FilterMonth"]</option> } else { <option value="month">@Localizer["FilterMonth"]</option> }
                    @if(ViewBag.ActivePeriod == "year"){ <option value="year" selected>@Localizer["FilterYear"]</option> } else { <option value="year">@Localizer["FilterYear"]</option> }
                </select>
            </form>
        </div>

        <div class="card-body p-3">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                { 
                    var durationMins = (int)((item.EndTime - item.StartTime)?.TotalMinutes ?? 0);

                    <a asp-controller="History" asp-action="Details" asp-route-id="@item.Id" class="history-row flex-column flex-md-row gap-4 text-decoration-none text-dark">
                        <div class="vehicle-img-placeholder flex-shrink-0">
                            <i class="bi @(item.Vehicle.Category.Contains("Scooter") ? "bi-scooter" : "bi-bicycle")"></i>
                        </div>
                        
                        <div class="flex-grow-1" style="min-width: 250px;">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <span class="badge bg-success text-white rounded-pill shadow-sm px-3 py-2">@item.Vehicle.Category</span>
                                <small class="text-muted fw-bold" style="font-size: 0.8rem;">@item.StartTime.AddHours(7).ToString("dd MMM yyyy • hh:mm tt")</small>
                            </div>
                            <div class="d-flex align-items-center mt-2 bg-light p-2 rounded-3">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi bi-circle-fill text-success" style="font-size: 0.6rem;"></i>
                                    <small class="text-dark fw-bold">Bắt đầu</small>
                                </div>
                                <i class="bi bi-arrow-right mx-3 text-muted"></i>
                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi bi-geo-alt-fill text-danger" style="font-size: 0.9rem;"></i>
                                    <small class="text-dark fw-bold">@item.ReturnStation.LocationName</small>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-4 text-center bg-light p-3 rounded-4">
                            <div>
                                <h5 class="fw-bold text-success mb-0">@durationMins <span class="fs-6">min</span></h5>
                                <small class="text-muted fw-bold" style="font-size: 0.7rem;">@Localizer["Duration"]</small>
                            </div>
                            <div style="border-left: 2px dashed #dee2e6;"></div>
                            <div>
                                <h5 class="fw-bold text-primary mb-0">@((durationMins * 0.25).ToString("0.0")) <span class="fs-6">km</span></h5>
                                <small class="text-muted fw-bold" style="font-size: 0.7rem;">@Localizer["Distance"]</small>
                            </div>
                        </div>

                        <div class="text-end ms-md-4 d-flex align-items-center gap-3">
                            <div>
                                <small class="text-muted d-block fw-bold mb-1" style="font-size: 0.7rem;">Tổng cộng</small>
                                <h4 class="fw-bold text-dark mb-0">@item.TotalDue.ToString("N0") đ</h4>
                            </div>
                            <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 35px; height: 35px;">
                                <i class="bi bi-chevron-right"></i>
                            </div>
                        </div>
                    </a>
                }
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-journal-x fs-1 d-block mb-3 opacity-25"></i>
                    <p class="fw-bold">@Localizer["NoRides"]</p>
                </div>
            }
            <div class="text-center py-4">
                <span class="badge bg-light text-muted border px-3 py-2 rounded-pill"><i class="bi bi-check2-all text-success me-1"></i> @Localizer["NoMoreRides"]</span>
            </div>
        </div>
    </div>
</div>