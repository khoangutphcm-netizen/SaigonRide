@model SaigonRide.Models.entities.RentalTransaction
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["PageTitle"].Value;

    var endTime = Model.EndTime ?? DateTime.Now;
    var durationMinutes = (int)(endTime - Model.StartTime).TotalMinutes;
    var pricePerMinute = Model.Vehicle?.PricePerMinute ?? 0;
    var subtotal = pricePerMinute * durationMinutes;
    var distanceKm = durationMinutes * 0.25; 
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
    .receipt-card { background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); border-radius: 1.5rem; border: none; overflow: hidden; box-shadow: 0 15px 35px rgba(0,0,0,0.1); }
    .receipt-header { background: linear-gradient(135deg, #198754 0%, #146c43 100%); color: white; padding: 2.5rem 1rem 4rem 1rem; text-align: center; position: relative; }
    #miniMap { height: 250px; width: 100%; z-index: 1; margin-top: -30px; border-radius: 1.5rem 1.5rem 0 0; box-shadow: 0 -10px 20px rgba(0,0,0,0.1); position: relative; }
    .vehicle-badge { width: 70px; height: 70px; background: white; color: #198754; border-radius: 50%; display: inline-flex; justify-content: center; align-items: center; box-shadow: 0 10px 20px rgba(0,0,0,0.15); margin-bottom: 1rem; border: 4px solid rgba(255,255,255,0.2); background-clip: padding-box; }
    body.dark-mode .receipt-card { background: #212529; }
</style>

<div class="container-fluid px-0 d-flex justify-content-center py-4">
    <div class="col-md-8 col-lg-6 col-xl-5">
        
        <div class="d-flex align-items-center mb-4 px-3">
            <a href="javascript:history.back()" class="btn btn-white bg-white shadow-sm rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;"><i class="bi bi-arrow-left fs-5 text-dark"></i></a>
            <div>
                <h4 class="fw-bold text-dark mb-0">@Localizer["PageTitle"]</h4>
                <span class="badge bg-success bg-opacity-10 text-success rounded-pill mt-1">#SR-@Model.Id.ToString().PadLeft(6, '0')</span>
            </div>
        </div>

        <div class="receipt-card mb-4 mx-3">
            <div class="receipt-header">
                <div class="vehicle-badge">
                    <i class="bi @(Model.Vehicle.Category.Contains("Scooter") ? "bi-scooter" : "bi-bicycle") fs-1"></i>
                </div>
                <h4 class="fw-bold mb-1">@Model.Vehicle.Category</h4>
                <p class="mb-0 opacity-75 fw-bold">@Model.StartTime.AddHours(7).ToString("dd MMM yyyy, hh:mm tt")</p>
                
                <span class="badge bg-white text-success position-absolute top-0 end-0 m-4 rounded-pill px-3 py-2 shadow-sm fw-bold">
                    <i class="bi bi-check-circle-fill me-1"></i> @Localizer["StatusCompleted"]
                </span>
            </div>

            <div id="miniMap"></div>

            <div class="p-4 p-md-5">
                <h6 class="fw-bold text-success text-uppercase mb-4 d-flex align-items-center gap-2" style="letter-spacing: 1px;">
                    <i class="bi bi-info-circle-fill"></i> @Localizer["TripDetails"]
                </h6>
                
                <div class="bg-light p-4 rounded-4 mb-4">
                    <div class="d-flex justify-content-between mb-3 align-items-center">
                        <div class="d-flex align-items-center gap-3"><div class="bg-white p-2 rounded-circle shadow-sm"><i class="bi bi-geo-alt-fill text-danger fs-5"></i></div> <span class="text-muted fw-bold">@Localizer["ReturnStation"]</span></div>
                        <span class="fw-bold text-dark text-end fs-6">@Model.ReturnStation.LocationName</span>
                    </div>
                    
                    <div class="d-flex justify-content-between mb-3 align-items-center">
                        <div class="d-flex align-items-center gap-3"><div class="bg-white p-2 rounded-circle shadow-sm"><i class="bi bi-clock-history text-warning fs-5"></i></div> <span class="text-muted fw-bold">@Localizer["Duration"]</span></div>
                        <span class="fw-bold text-dark fs-6">@durationMinutes @Localizer["Minutes"]</span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center gap-3"><div class="bg-white p-2 rounded-circle shadow-sm"><i class="bi bi-signpost-split text-primary fs-5"></i></div> <span class="text-muted fw-bold">@Localizer["Distance"]</span></div>
                        <span class="fw-bold text-dark fs-6">@distanceKm.ToString("0.0") km</span>
                    </div>
                </div>

                <h6 class="fw-bold text-success text-uppercase mb-4 d-flex align-items-center gap-2 mt-5" style="letter-spacing: 1px;">
                    <i class="bi bi-receipt"></i> @Localizer["PaymentSummary"]
                </h6>

                <div class="d-flex justify-content-between mb-3">
                    <span class="text-muted fw-bold">@Localizer["Subtotal"]</span>
                    <span class="fw-bold text-dark fs-6">@subtotal.ToString("N0") đ</span>
                </div>

                @if (Model.IsDiscountApplied)
                {
                    <div class="d-flex justify-content-between mb-3 text-warning">
                        <span class="fw-bold"><i class="bi bi-tags-fill me-1"></i> @Localizer["Discount"]</span>
                        <span class="fw-bold fs-6">-15%</span>
                    </div>
                }

                <div class="p-4 bg-success bg-opacity-10 rounded-4 d-flex justify-content-between align-items-center mt-4 border border-success border-opacity-25">
                    <span class="fw-bold text-success text-uppercase" style="letter-spacing: 1px;">@Localizer["TotalPaid"]</span>
                    <h2 class="fw-bold text-success mb-0">@Model.TotalDue.ToString("N0") đ</h2>
                </div>
            </div>
        </div>
        
        <div class="d-flex gap-3 px-3">
            <button class="btn btn-white bg-white border shadow-sm flex-grow-1 rounded-pill py-3 fw-bold text-dark" onclick="window.print()">
                <i class="bi bi-printer me-2"></i> @Localizer["PrintReceipt"]
            </button>
            <button class="btn btn-danger rounded-pill py-3 fw-bold px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#reportModal">
                <i class="bi bi-flag-fill me-2"></i> Báo cáo
            </button>
        </div>

        <div class="modal fade" id="reportModal" tabindex="-1" aria-labelledby="reportModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg rounded-4">
                    <div class="modal-header border-bottom-0 p-4">
                        <h5 class="modal-title fw-bold text-dark" id="reportModalLabel">Báo cáo sự cố</h5>
                        <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form method="post" action="/Reports/CreateReport">
                        <div class="modal-body px-4 py-2">
                            <input type="hidden" name="rentalTransactionId" value="@Model.Id" />
                            <div class="mb-4">
                                <label class="form-label fw-bold text-muted small text-uppercase">Tiêu đề báo cáo</label>
                                <input type="text" class="form-control form-control-lg rounded-3 shadow-none bg-light border-0" name="title" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold text-muted small text-uppercase">Mô tả chi tiết</label>
                                <textarea class="form-control rounded-3 shadow-none bg-light border-0" name="description" rows="5" required></textarea>
                            </div>
                        </div>
                        <div class="modal-footer border-top-0 p-4">
                            <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Hủy</button>
                            <button type="submit" class="btn btn-danger rounded-pill px-5 fw-bold shadow-sm">Gửi báo cáo</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
    var lat = @(Model.ReturnStation.Latitude != 0 ? Model.ReturnStation.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture) : "10.776889");
    var lng = @(Model.ReturnStation.Longitude != 0 ? Model.ReturnStation.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture) : "106.700806");
    
    var map = L.map('miniMap', { zoomControl: false, dragging: false, scrollWheelZoom: false }).setView([lat, lng], 15);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

    var customIcon = L.divIcon({
        className: 'custom-div-icon',
        html: `<div class="bg-white rounded-circle shadow-lg border border-4 border-danger d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;"><i class="bi bi-geo-alt-fill text-danger fs-3"></i></div>`,
        iconSize: [50, 50],
        iconAnchor: [25, 50]
    });
    
    L.marker([lat, lng], { icon: customIcon }).addTo(map);
</script>